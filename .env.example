# ---------------------------------------------------------------------------
# Blackbox AI - example configuration
# Copy to `.env` and fill in. Every value below has a safe default except the
# provider credentials you actually want the gateway to use on your behalf.
# ---------------------------------------------------------------------------

# --- MongoDB (the sovereign vault) -----------------------------------------
# Local Atlas image speaks a single-node replica set; directConnection avoids
# SRV/replica-set discovery against a host that only resolves inside Docker.
GATEWAY_MONGO_URI=mongodb://localhost:27017/?directConnection=true
GATEWAY_MONGO_DB=blackbox_ai
GATEWAY_MONGO_COLLECTION=intents

# --- Deployment posture -----------------------------------------------------
# `dev` is permissive for local work; `production` is secure-by-default: client
# auth is always enforced and startup fails fast on an insecure config (e.g. no
# GATEWAY_TOKENS). Set this to `production` before exposing the gateway.
GATEWAY_ENV=dev

# --- Gateway behaviour ------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=INFO
# Emit structured JSON logs (true in prod/containers, false for pretty console).
GATEWAY_LOG_JSON=true

# Client auth. When false the gateway relays whatever credential the client SDK
# sends upstream (easy on-ramp) - but it logs a loud warning, and `production`
# forces auth on regardless. Set to true + list accepted tokens for custody.
GATEWAY_REQUIRE_AUTH=false
# Comma-separated list of accepted gateway tokens (required in production).
GATEWAY_TOKENS=

# --- Telemetry plane (out-of-band, fail-open) ------------------------------
# Bounded queue: when full, captures are dropped (logged) rather than blocking
# the request path. Size for your peak burst x capture size.
GATEWAY_TELEMETRY_QUEUE_MAXSIZE=10000
GATEWAY_TELEMETRY_WORKERS=2
GATEWAY_TELEMETRY_BATCH_SIZE=50
GATEWAY_TELEMETRY_FLUSH_INTERVAL_S=1.0
# Cap on bytes captured per response (protects memory on huge generations).
GATEWAY_TELEMETRY_MAX_CAPTURE_BYTES=8388608

# --- Upstream HTTP ----------------------------------------------------------
# LLM streams can be long-lived; keep the read budget generous.
GATEWAY_HTTP_TIMEOUT_S=300
GATEWAY_HTTP_CONNECT_TIMEOUT_S=10

# --- Request limits ---------------------------------------------------------
# Reject inbound request bodies larger than this many bytes with 413. The relay
# buffers each body to forward and capture it; this bounds data-plane memory.
GATEWAY_MAX_REQUEST_BYTES=10485760
# Hard ceiling on concurrently in-flight requests; excess get a fast 503 with a
# Retry-After header instead of being queued. Worst-case data-plane memory is
# roughly this x (GATEWAY_MAX_REQUEST_BYTES + GATEWAY_TELEMETRY_MAX_CAPTURE_BYTES).
GATEWAY_MAX_CONCURRENT_REQUESTS=100

# --- Abuse prevention -------------------------------------------------------
# Per-client sliding-window rate limit (keyed by gateway token when auth is on,
# else by client IP). On by default; over-limit clients get 429 + Retry-After.
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REQUESTS=120
GATEWAY_RATE_LIMIT_WINDOW_S=60

# --- Provider sovereign credentials ----------------------------------------
# If a provider key is set, the gateway injects it upstream and clients only
# need a gateway token. If left blank, the gateway transparently forwards the
# credential the client SDK already sends (zero-config relay).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Azure has no universal host: set the endpoint of your resource.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Ollama is keyless; point at your host (defaults to local daemon).
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Sovereign features - ON by default (secure-by-default). Disable per-feature
# below if your environment can't support them (e.g. a plain-MongoDB dev box).
# ---------------------------------------------------------------------------

# --- Queryable Encryption (client-side, MongoDB never sees plaintext) -------
# Encrypts raw_payload and the model's content/chain-of-thought before they
# reach the database. ON by default. FAIL-CLOSED: with a bad/missing key or a
# missing crypt_shared library, the gateway refuses to start.
#
#   1. make gen-key        # appends GATEWAY_ENCRYPTION_KEY=... below
#   2. make up && make init
#
# The Docker image bakes in crypt_shared and sets GATEWAY_CRYPT_SHARED_LIB_PATH
# automatically; set it yourself only for non-Docker runs. To run against a
# plain MongoDB without QE, set GATEWAY_ENCRYPTION_ENABLED=false.
GATEWAY_ENCRYPTION_ENABLED=true
GATEWAY_ENCRYPTION_KEY=
# GATEWAY_ENCRYPTION_KEY_VAULT_NS=blackbox_ai.__keyvault
# GATEWAY_CRYPT_SHARED_LIB_PATH=/opt/mongo/crypt_shared/mongo_crypt_v1.so

# --- Embeddings / Vector + hybrid "time-travel" search ----------------------
# Voyage AI by default (`voyage-code-3`). Supply VOYAGE_API_KEY to activate
# semantic + hybrid search; without a key the gateway runs with search disabled
# (fail-open). Embeddings are generated off the hot path (telemetry plane).
GATEWAY_EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=
GATEWAY_EMBEDDING_MODEL=voyage-code-3
GATEWAY_EMBEDDING_DIMS=1024
# Circuit breaker around the embedder: after N consecutive batch failures, stop
# calling Voyage for the cooldown window (still fail-open - docs keep no vector).
GATEWAY_EMBEDDING_BREAKER_THRESHOLD=5
GATEWAY_EMBEDDING_BREAKER_COOLDOWN_S=30
GATEWAY_VECTOR_INDEX_NAME=intent_vector_index
# Atlas Search (full-text) index powering hybrid search via $rankFusion.
GATEWAY_SEARCH_INDEX_NAME=intent_text_index

# --- Token cache (exact-match, opt-in) --------------------------------------
# When enabled, clients opt in per request with header `X-Intent-Cache: on`
# (or flip CACHE_DEFAULT_ON to cache every eligible request). Lookups are
# time-bounded and fail-open; entries expire via a TTL index.
GATEWAY_CACHE_ENABLED=false
GATEWAY_CACHE_DEFAULT_ON=false
GATEWAY_CACHE_TTL_S=3600
GATEWAY_CACHE_COLLECTION=cache
GATEWAY_CACHE_LOOKUP_TIMEOUT_S=0.25

# --- Admin / search API -----------------------------------------------------
# Required to expose POST /admin/search. When unset, the admin API is disabled.
GATEWAY_ADMIN_TOKEN=
# Protect GET /metrics with the admin token (open by default for scrapers).
GATEWAY_METRICS_PROTECTED=false
